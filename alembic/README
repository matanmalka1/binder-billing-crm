a1b2c3d4e5f6         (add entity_audit_logs table — 2026-04-05)
71ead2aae8c6         (set advance_payments.paid_amount non-nullable with default 0 — 2026-04-05)
214426106435         (fix vat_work_item unique constraint with partial index for soft delete — 2026-04-05)
6e3f2b1d0c8a         (fix vat_invoices document_type enum collision — 2026-03-29)
