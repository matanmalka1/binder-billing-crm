@startuml
' Domain: annual_reports  |  mode: full
' Edge legend: --> ORM relationship()   ..> FK-only (no relationship)
hide empty members
skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam ArrowColor #555555
skinparam ClassBorderColor #888888
skinparam ClassBackgroundColor #FAFAFA

class AnnualReportAnnexData <<annual_report_annex_data>> {
  +id : int <<PK>>
  +schedule_entry_id : int <<FK→annual_report_schedules>>
  +line_number : int
  +data : json
  +data_version : int
  +notes : text?
  +created_at : datetime
  +updated_at : datetime?
}

enum CreditPointReason {
  resident
  academic_degree
  discharged_soldier
  new_immigrant
  single_parent
}

class AnnualReportCreditPoint <<annual_report_credit_points>> {
  +id : int <<PK>>
  +annual_report_id : int <<FK→annual_reports>>
  +reason : CreditPointReason
  +points : decimal(5,2)
  +notes : str?
}

class AnnualReportDetail <<annual_report_details>> {
  +id : int <<PK>>
  +report_id : int <<FK→annual_reports>>
  +pension_contribution : decimal(12,2)?
  +donation_amount : decimal(12,2)?
  +other_credits : decimal(12,2)?
  +client_approved_at : datetime?
  +internal_notes : text?
  +amendment_reason : str(500)?
  +created_at : datetime
  +updated_at : datetime?
}

enum ExpenseCategoryType {
  office_rent
  professional_services
  salaries
  depreciation
  vehicle
  marketing
  insurance
  communication
  travel
  training
  bank_fees
  other
}

class AnnualReportExpenseLine <<annual_report_expense_lines>> {
  +id : int <<PK>>
  +annual_report_id : int <<FK→annual_reports>>
  +category : ExpenseCategoryType
  +amount : decimal(14,2)
  +recognition_rate : decimal(5,2)
